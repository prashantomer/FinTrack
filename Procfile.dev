backend:  cd backend && bundle exec rails server -p 8000 2>&1 | tee ../logs/backend.log
frontend: cd frontend && /Users/prashanto/.nvm/versions/node/v24.15.0/bin/npm run dev 2>&1 | tee ../logs/frontend.log
